" prop=\"shiyanshimingcheng\">\n              <el-input v-model=\"ruleForm.shiyanshimingcheng\" \n                placeholder=\"实验室名称\" readonly></el-input>\n          </el-form-item>\n        </div>\n      </el-col>\n      <el-col :span=\"12\">\n        <el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"预约内容\" prop=\"yuyueneirong\">\n          <el-input v-model=\"ruleForm.yuyueneirong\" \n              placeholder=\"预约内容\" clearable  :readonly=\"ro.yuyueneirong\"></el-input>\n        </el-form-item>\n        <div v-else>\n          <el-form-item class=\"input\" label=\"预约内容\" prop=\"yuyueneirong\">\n              <el-input v-model=\"ruleForm.yuyueneirong\" \n                placeholder=\"预约内容\" readonly></el-input>\n          </el-form-item>\n        </div>\n      </el-col>\n      <el-col :span=\"12\">\n        <el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"预约时间\" prop=\"yuyueshijian\">\n          <el-input v-model=\"ruleForm.yuyueshijian\" \n              placeholder=\"预约时间\" clearable  :readonly=\"ro.yuyueshijian\"></el-input>\n        </el-form-item>\n        <div v-else>\n          <el-form-item class=\"input\" label=\"预约时间\" prop=\"yuyueshijian\">\n              <el-input v-model=\"ruleForm.yuyueshijian\" \n                placeholder=\"预约时间\" readonly></el-input>\n          </el-form-item>\n        </div>\n      </el-col>\n      <el-col :span=\"12\">\n        <el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"学号\" prop=\"xuehao\">\n          <el-input v-model=\"ruleForm.xuehao\" \n              placeholder=\"学号\" clearable  :readonly=\"ro.xuehao\"></el-input>\n        </el-form-item>\n        <div v-else>\n          <el-form-item class=\"input\" label=\"学号\" prop=\"xuehao\">\n              <el-input v-model=\"ruleForm.xuehao\" \n                placeholder=\"学号\" readonly></el-input>\n          </el-form-item>\n        </div>\n      </el-col>\n      <el-col :span=\"12\">\n        <el-form-item class=\"input\" v-if=\"type!='in