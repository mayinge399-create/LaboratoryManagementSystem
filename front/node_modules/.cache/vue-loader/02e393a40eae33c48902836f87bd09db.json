 <div class=\"stat-card\" v-for=\"item in categoryCards\" :key=\"item.key\">\n        <div class=\"label\">{{ item.label }}</div>\n        <div class=\"value\">{{ item.value }}</div>\n      </div>\n      <div class=\"stat-card\" v-for=\"item in statusCards\" :key=\"item.key\">\n        <div class=\"label\">{{ item.label }}</div>\n        <div class=\"value\">{{ item.value }}</div>\n      </div>\n    </div>\n\n    <div class=\"recent-card\">\n      <div class=\"recent-title\">最近新增设备（5条）</div>\n      <el-table :data=\"stats.recentList\" border size=\"small\" style=\"width: 100%\">\n        <el-table-column prop=\"shebeimingcheng\" label=\"设备名称\" />\n        <el-table-column prop=\"category\" label=\"分类\" width=\"140\" />\n        <el-table-column prop=\"shebeizhuangtai\" label=\"状态\" width=\"140\" />\n      </el-table>\n    </div>\n  </div>\n</template>\n<script>\nimport router from '@/router/router-static'\nexport default {\n  data() {\n    return {\n      stats: {\n        total: 0,\n        categoryStats: {},\n        statusStats: {},\n        recentList: []\n      }\n    }\n  },\n  computed: {\n    categoryCards() {\n      return [\n        { key: 'bio', label: '生物设备', value: this.stats.categoryStats['生物'] || 0 },\n        { key: 'chem', label: '化学设备', value: this.stats.categoryStats['化学'] || 0 },\n        { key: 'phy', label: '物理设备', value: this.stats.categoryStats['物理'] || 0 },\n        { key: 'other', label: '其他设备', value: this.stats.categoryStats['其他'] || 0 }\n      ]\n    },\n    statusCards() {\n      return [\n        { key: 'normal', label: '正常设备', value: this.stats.statusStats['正常'] || 0 },\n        { key: 'repair', label: '维修设备', value: this.stats.statusStats['维修'] || 0 },\n        { key: 'scrap', label: '报废设备', value: this.stats.statusStats['报废'] || 0 }\n      ]\n    }\n  },\n  mounted(){\n    this.init();\n  },\n  methods:{\n    init(){\n        if(this.$storage.get('Token')){\n        this.$http({\n            url: `${this.$storage.get('sessionTable')}/session`,\n            method: \"get\"\n        }).then(({ data }) => {\n            if (data && data.code != 0) {\n            router.push({ name: 'login' })\n            } else {\n              this.getDashboardStats()\n            }\n        });\n        }else{\n            router.push({ name: 'login' })\n        }\n    },\n    getDashboardStats() {\n      this.$http({\n        url: 'shiyanshebei/dashboard',\n        method: 'get'\n      }).then(({ data }) => {\n        if (data && data.code === 0) {\n          this.stats = data.data || this.stats\n        }\n      })\n    }\n  }\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.content {\n  width: 100%;\n  min-height: 500px;\n  padding: 12px;\n  box-sizing: border-box;\n  background: #e8f5e9;\n  border-radius: 14px;\n}\n\n.headline {\n  font-size: 28px;\n  font-weight: 700;\n  color: #2c3e2f;\n  margin-bottom: 16px;\n  text-align: left;\n}\n\n.stat-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));\n  gap: 12px;\n}\n\n.stat-card {\n  background: #f4fbf4;\n  border: 1px solid #cfe9d2;\n  border-radius: 12px;\n  padding: 14px;\n}\n\n.label {\n  color: #5c6f5f;\n  font-size: 14px;\n}\n\n.value {\n  margin-top: 8px;\n  font-size: 28px;\n  color: #2c3e2f;\n  font-weight: 700;\n}\n\n.recent-card {\n  margin-top: 16px;\n  background: #f4fbf4;\n  border: 1px solid #cfe9d2;\n  border-radius: 12px;\n  padding: 14px;\n}\n\n.recent-title {\n  font-size: 16px;\n  color: #2c3e2f;\n  font-weight: 600;\n  margin-bottom: 10px;\n}\n\n.content ::v-deep .el-table th {\n  background: #edf8ee !important;\n  color: #2c3e2f !important;\n}\n\n.content ::v-deep .el-table td {\n  color: #333 !important;\n}\n\n@media screen and (max-width: 768px) {\n  .headline {\n    font-size: 22px;\n  }\n\n  .value {\n    font-size: 22px;\n  }\n}\n</style>"]}]}